mixed-port: 7890
allow-lan: false
bind-address: "*"
external-controller: 127.0.0.1:9093
log-level: warning

find-process-mode: strict
global-client-fingerprint: chrome

ipv6: true
tcp-concurrent: true
unified-delay: true

geo-auto-update: true
geo-update-interval: 24
geodata-loader: standard

geox-url:
